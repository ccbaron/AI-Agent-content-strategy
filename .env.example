GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

TAVILY_API_KEY=your_tavily_api_key_here

KNOWLEDGE_DIR=knowledge
KNOWLEDGE_INDEX_PATH=data/knowledge-index.json

PORT=3000
NODE_ENV=development

# App mode:
# - cost_saver: limits tool usage and keeps responses more economical
# - showcase: allows the full demo behavior for portfolio/demo purposes
APP_MODE=cost_saver
EVALUATOR_ENABLED=true
MAX_CONVERSATION_MESSAGES=6
TAVILY_MAX_RESULTS=3